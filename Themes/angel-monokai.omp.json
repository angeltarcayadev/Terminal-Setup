{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        { "background": "#FD971F", "foreground": "#1A1B26", "style": "powerline", "template": " \ue62a ", "type": "os" },
        { "background": "#A6E22E", "foreground": "#1A1B26", "style": "powerline", "template": " \uf07b {{ .Path }} ", "properties": { "style": "folder" }, "type": "path" },
        { "background": "#F92672", "foreground": "#1A1B26", "style": "powerline", "template": " \uf126 {{ .HEAD }} ", "type": "git" }
      ],
      "type": "prompt"
    }
  ],
  "version": 2
}
